eqo(V0,V1):- att(V2,id,V0),cora(V2),att(V2,type,V4),att(V3,type,V5),cora(V3),att(V3,id,V1),sim(V4,V5,S0), S0>=85.

sim(X,X,100):- att(_,_,X).
sim(X,Y,T):- sim(Y,X,T).
sim(X,Y,T):- sim(Y,X,T). 
sim(X,Y,T1):- sim(X,Y,T), sim_thresh(T1), T>T1.

pos_covered(ID):- eqo(X,Y), pos(eqo(X,Y),ID).
pos_covered(ID):- eqo(X,Y), pos(eqo(Y,X),ID).

neg_covered(ID):- eqo(X,Y), neg(eqo(X,Y),ID).
neg_covered(ID):- eqo(X,Y), neg(eqo(Y,X),ID).


#show pos_covered/1.
#show neg_covered/1.

